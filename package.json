{
  "name": "@clamp-sh/mcp",
  "version": "5.4.0",
  "description": "Analytics MCP server for Clamp Analytics. Gives Claude, Cursor, VS Code, Windsurf, and Cline tools for traffic, pages, events, revenue, errors, funnels, cohorts, and alerts. Stdio + hosted Remote MCP.",
  "license": "MIT",
  "homepage": "https://clamp.sh/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clamp-sh/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/clamp-sh/mcp/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "analytics",
    "web-analytics",
    "product-analytics",
    "ai-agents",
    "claude",
    "claude-code",
    "claude-desktop",
    "cursor",
    "vscode",
    "windsurf",
    "cline",
    "funnels",
    "cohorts",
    "revenue-analytics",
    "remote-mcp",
    "clamp"
  ],
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./tools": {
      "types": "./dist/tools.d.mts",
      "import": "./dist/tools.mjs"
    }
  },
  "bin": {
    "clamp-mcp": "dist/index.mjs"
  },
  "scripts": {
    "build": "tsup src/index.ts src/tools.ts --format esm --dts",
    "dev": "tsup src/index.ts src/tools.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5"
  }
}
